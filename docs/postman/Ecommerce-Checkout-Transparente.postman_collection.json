{
  "info": {
    "name": "Ecommerce Checkout Transparente",
    "_postman_id": "8f6d9c5a-5d7f-4a8f-9b22-7d4a2a6f4b3c",
    "description": "Fluxo E2E: registro, verificação, login, criar pedido e pagamento transparente (Pix/Boleto/Cartão).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "email", "value": "user1@example.com" },
    { "key": "password", "value": "P@ssw0rd123" },
    { "key": "verifyToken", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"name\": \"User One\"\n}"
        }
      }
    },
    {
      "name": "Auth - Verify Email",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/verify-email",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{verifyToken}}\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "pm.collectionVariables.set('accessToken', data.accessToken || '');",
              "pm.collectionVariables.set('refreshToken', data.refreshToken || '');"
            ]
          }
        }
      ]
    },
    {
      "name": "Orders - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/orders",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    { \"item1\": \"00000000-0000-0000-0000-000000000001\", \"item2\": 1 }\n  ]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "pm.collectionVariables.set('orderId', data.id || '');"
            ]
          }
        }
      ]
    },
    {
      "name": "Payments - Transparent Pix",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/payments/transparent",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"method\": \"pix\",\n  \"amount\": 10.0,\n  \"paymentMethodId\": \"pix\",\n  \"description\": \"Pedido {{orderId}}\",\n  \"payer\": {\n    \"email\": \"{{email}}\",\n    \"firstName\": \"User\",\n    \"lastName\": \"One\",\n    \"identificationType\": \"CPF\",\n    \"identificationNumber\": \"12345678900\",\n    \"phoneAreaCode\": \"11\",\n    \"phoneNumber\": \"999999999\"\n  }\n}"
        }
      }
    },
    {
      "name": "Payments - Transparent Boleto",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/payments/transparent",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"method\": \"boleto\",\n  \"amount\": 10.0,\n  \"paymentMethodId\": \"bolbradesco\",\n  \"description\": \"Pedido {{orderId}}\",\n  \"payer\": {\n    \"email\": \"{{email}}\",\n    \"firstName\": \"User\",\n    \"lastName\": \"One\",\n    \"identificationType\": \"CPF\",\n    \"identificationNumber\": \"12345678900\",\n    \"phoneAreaCode\": \"11\",\n    \"phoneNumber\": \"999999999\"\n  }\n}"
        }
      }
    },
    {
      "name": "Payments - Transparent Card",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/payments/transparent",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"method\": \"card\",\n  \"amount\": 10.0,\n  \"description\": \"Pedido {{orderId}}\",\n  \"payer\": {\n    \"email\": \"{{email}}\",\n    \"firstName\": \"User\",\n    \"lastName\": \"One\",\n    \"identificationType\": \"CPF\",\n    \"identificationNumber\": \"12345678900\",\n    \"phoneAreaCode\": \"11\",\n    \"phoneNumber\": \"999999999\"\n  },\n  \"card\": {\n    \"token\": \"<CARD_TOKEN>\",\n    \"installments\": 1,\n    \"paymentMethodId\": \"visa\",\n    \"issuerId\": null\n  }\n}"
        }
      }
    },
    {
      "name": "Payments - Get By Order",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/payments/order/{{orderId}}"
      }
    }
  ]
}
