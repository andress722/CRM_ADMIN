{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "UseInMemory": false,
    "SeedData": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://127.0.0.1:3000"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=ecommerce;Username=admin;Password=changeme;SslMode=disable;"
  },
  "Jwt": {
    "Issuer": "ecommerce-api",
    "Audience": "ecommerce-admin",
    "SecretKey": "DEV_ONLY_CHANGE_ME_TO_A_LONG_RANDOM_SECRET",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 120
      },
      {
        "Endpoint": "*:/api/v1/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*:/api/v1/auth/refresh",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "*:/api/webhooks/mercadopago",
        "Period": "1m",
        "Limit": 120
      },
      {
        "Endpoint": "*:/api/v1/payments/checkout",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "*:/api/v1/refunds/*/process",
        "Period": "1m",
        "Limit": 20
      }
    ]
  },
  "Auth": {
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15,
    "EmailVerificationMinutes": 60,
    "PasswordResetMinutes": 30
  },
  "Payments": {
    "Provider": "MercadoPago",
    "MercadoPago": {
      "AccessToken": "CHANGE_ME",
      "WebhookUrl": "https://your-domain.com/api/webhooks/mercadopago",
      "Currency": "BRL",
      "WebhookSecret": "CHANGE_ME",
      "WebhookSignatureFormat": "ts_requestid_body"
    }
  },
  "Shipping": {
    "Correios": {
      "BaseUrl": "",
      "AccessToken": ""
    }
  },
  "Email": {
    "Provider": "SendGrid",
    "FromEmail": "no-reply@ecommerce.local",
    "FromName": "Ecommerce",
    "BaseUrl": "http://localhost:3000",
    "SendGrid": {
      "ApiKey": ""
    },
    "Ses": {
      "Region": "us-east-1"
    }
  },
  "Sentry": {
    "Dsn": "",
    "TracesSampleRate": 0.0,
    "SendDefaultPii": false
  },
  "Observability": {
    "EnableOpenTelemetry": true,
    "OtlpEndpoint": "" /* set to e.g. http://localhost:4317 to enable OTLP exporter */
  }
}
