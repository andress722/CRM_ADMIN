{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "UseInMemory": false,
    "SeedData": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:3003",
      "http://localhost:3006",
      "http://127.0.0.1:3003",
      "http://127.0.0.1:3006",
      "http://127.0.0.1:3000"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=ecommerce;Username=admin;Password=changeme;SslMode=disable;"
  },
  "Jwt": {
    "Issuer": "ecommerce-api",
    "Audience": "ecommerce-admin",
    "SecretKey": "CHANGE_ME_USE_ENV",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 120
      },
      {
        "Endpoint": "*:/api/v1/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*:/api/v1/auth/refresh",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "*:/api/webhooks/mercadopago",
        "Period": "1m",
        "Limit": 120
      },
      {
        "Endpoint": "*:/api/v1/payments/checkout",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "*:/api/v1/refunds/*/process",
        "Period": "1m",
        "Limit": 20
      },
      {
        "Period": "1m",
        "Endpoint": "*:/api/v1/auth/register",
        "Limit": 10
      },
      {
        "Period": "1m",
        "Endpoint": "*:/api/v1/auth/forgot-password",
        "Limit": 10
      },
      {
        "Period": "1m",
        "Endpoint": "*:/api/v1/auth/reset-password",
        "Limit": 15
      }
    ]
  },
  "Auth": {
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15,
    "EmailVerificationMinutes": 60,
    "PasswordResetMinutes": 30,
    "AllowRefreshTokenInBody": false,
    "AllowInsecureCookiesInDevelopment": true
  },
  "Networking": {
    "TrustedProxies": []
  },
  "Payments": {
    "Provider": "MercadoPago",
    "MercadoPago": {
      "AccessToken": "CHANGE_ME",
      "WebhookUrl": "https://your-domain.com/api/webhooks/mercadopago",
      "Currency": "BRL",
      "WebhookSecret": "CHANGE_ME",
      "WebhookSignatureFormat": "ts_requestid_body"
    }
  },
  "Shipping": {
    "Correios": {
      "BaseUrl": "",
      "AccessToken": ""
    }
  },
  "Email": {
    "Provider": "SendGrid",
    "FromEmail": "no-reply@ecommerce.local",
    "FromName": "Ecommerce",
    "BaseUrl": "http://localhost:3000",
    "SendGrid": {
      "ApiKey": ""
    },
    "Ses": {
      "Region": "us-east-1"
    }
  },
  "Sentry": {
    "Dsn": "",
    "TracesSampleRate": 0.0,
    "SendDefaultPii": false
  },
  "Observability": {
    "EnableOpenTelemetry": true,
    "OtlpEndpoint": ""
  },
  "Swagger": {
    "Enabled": true
  },
  "Security": {
    "RequireAdmin2FA": false,
    "Captcha": {
      "Enabled": false,
      "VerifyUrl": "https://challenges.cloudflare.com/turnstile/v0/siteverify",
      "SecretKey": ""
    }
  },
  "Reports": {
    "EmailRecipients": "",
    "DailyHourUtc": 8,
    "WeeklyHourUtc": 9,
    "MonthlyHourUtc": 10
  },
  "Alerts": {
    "EmailRecipients": "",
    "CancelRateThreshold": 0.2,
    "CartConversionThreshold": 0.15
  },
  "Loyalty": {
    "CashbackRate": 0.02
  },
  "CartRecovery": {
    "Enabled": true
  },
  "DataRetention": {
    "AnalyticsDays": 180
  },
  "Subscriptions": {
    "Plans": [
      {
        "Interval": "month",
        "Price": 19.9,
        "Features": [
          "Frete com desconto",
          "Ofertas semanais"
        ],
        "Highlighted": false,
        "Name": "Starter",
        "Id": "starter"
      },
      {
        "Interval": "month",
        "Price": 49.9,
        "Features": [
          "Frete gratis",
          "Suporte prioritario",
          "Cashback aumentado"
        ],
        "Highlighted": true,
        "Name": "Pro",
        "Id": "pro"
      },
      {
        "Interval": "month",
        "Price": 99.9,
        "Features": [
          "Frete expresso gratis",
          "Ofertas exclusivas",
          "Atendimento dedicado"
        ],
        "Highlighted": false,
        "Name": "Elite",
        "Id": "elite"
      }
    ],
    "MaxRetryAttempts": 3,
    "RetryDelayHours": 24,
    "Billing": {
      "WorkerIntervalMinutes": 10,
      "WorkerBatchSize": 100,
      "WebhookSignatureFormat": "ts_requestid_body",
      "ChargePath": "/charges",
      "ApiKey": "",
      "WebhookSecret": "",
      "Currency": "BRL",
      "BaseUrl": ""
    }
  },
  "Search": {
    "Provider": "database",
    "BaseUrl": "",
    "ApiKey": "",
    "ApiKeyHeader": "Authorization",
    "IndexName": "products",
    "QueryPath": "",
    "TimeoutSeconds": 5
  },
  "Mobile": {
    "DeepLinks": {
      "AllowedSchemes": [
        "ecommerce"
      ]
    }
  },
  "Push": {
    "Provider": "log",
    "Expo": {
      "AccessToken": "",
      "BaseUrl": "https://exp.host/--/api/v2/push/send"
    },
    "Generic": {
      "ApiKey": "",
      "SendUrl": "",
      "ApiKeyHeader": "Authorization"
    }
  }
}

