ASPNETCORE_ENVIRONMENT=Development
# Payment provider (Production: do not use Stub)
Payments__Provider=MercadoPago
Payments__MercadoPago__AccessToken=CHANGE_ME
# Email provider (Production: do not use Console)
Email__Provider=Gmail
Email__FromEmail=no-reply@example.com
Email__FromName=InfoTechGamer
Email__BaseUrl=http://localhost:3006
Email__Gmail__User=CHANGE_ME
Email__Gmail__Pass=CHANGE_ME
Email__Gmail__Host=smtp.gmail.com
Email__Gmail__Port=587
Email__Gmail__EnableSsl=true
Observability__EnableOpenTelemetry=false
Observability__OtlpEndpoint=
Logging__LogLevel__Default=Information




# Seed admin bootstrap (staging/non-prod)
SeedAdmin__Email=admin@example.com
SeedAdmin__Password=demo123
SeedAdmin__Name=Admin User
SeedAdmin__ForceResetPassword=false
